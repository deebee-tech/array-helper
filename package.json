{
  "name": "@deebeetech/array-helper",
  "version": "3.0.0",
  "description": "A small collection of extra methods for arrays that we mostly needed from LoDash and Underscore that we didn't want to carry the weight of those installs.",
  "homepage": "https://github.com/deebee-tech/array-helper",
  "license": "MIT",
  "private": false,
  "author": {
    "name": "Sandy Weatherby",
    "email": "unicornbeachdiaries@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deebee-tech/array-helper"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "types": "dist/index.d.mts",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "array",
    "lodash",
    "underscore",
    "helper"
  ],
  "scripts": {
    "build": "tsdown && cpy './package.json' './dist/' && cpy './README.md' './dist/' && cpy './CHANGELOG.md' './dist/' && cpy './LICENSE' './dist/'",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "spell": "cspell --no-progress \"**\"",
    "test": "vitest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.13.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sebbo2002/semantic-release-jsr": "^4.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "cpy-cli": "^7.0.0",
    "cspell": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "jsr": "^0.14.3",
    "prettier": "^3.9.5",
    "semantic-release": "^25.0.7",
    "semantic-release-replace-plugin": "^1.2.7",
    "tsdown": "^0.22.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
